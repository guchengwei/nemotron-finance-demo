# =============================================================================
# Nemotron Financial Survey Demo — Environment Configuration
# Copy this file to .env and edit for your environment.
# Run ./setup-env.sh for an interactive guided setup.
# =============================================================================

# --- LLM -------------------------------------------------------------------
# URL of the OpenAI-compatible vLLM server
VLLM_URL=http://localhost:8000/v1

# Model name as registered in vLLM (must match --model arg at vLLM launch)
VLLM_MODEL=nvidia/NVIDIA-Nemotron-Nano-9B-v2-Japanese

# Set to true to run without a GPU/vLLM (uses template-based mock responses)
MOCK_LLM=false

# LLM generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
REPORT_MAX_TOKENS=4096

# Max simultaneous persona LLM calls
LLM_CONCURRENCY=4

# --- Data ------------------------------------------------------------------
# Directory for SQLite databases (will be created if absent)
DATA_DIR=/data/nemotron-finance

# Path to the Nemotron-Personas-Japan parquet file.
# Leave blank to auto-download from HuggingFace on first run (~1.7 GB).
PERSONA_PARQUET_PATH=

# SQLite DB paths (inside DATA_DIR by default)
DB_PATH=/data/nemotron-finance/personas.db
HISTORY_DB_PATH=/data/nemotron-finance/history.db

# --- Server ----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# Allowed CORS origins (JSON array)
CORS_ORIGINS=["*"]
